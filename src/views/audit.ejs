<%- include('partials/header', { title }) %>
<section class="panel">
  <div class="page-head">
    <div>
      <h1>Audit Logs</h1>
      <p class="page-subtitle">Security and activity events across the console.</p>
    </div>
  </div>

  <div class="table-wrap premium-table">
    <table>
      <thead>
        <tr>
          <th>Time</th>
          <th>Actor</th>
          <th>Action</th>
          <th>Target</th>
          <th>Success</th>
        </tr>
      </thead>
      <tbody>
        <% logs.forEach((log) => { %>
          <tr>
            <td><%= new Date(log.created_at).toLocaleString('en-IN', { timeZone: 'Asia/Kolkata' }) %></td>
            <td><%= log.actor_username || '-' %></td>
            <td><%= log.action %></td>
            <td><%= log.target_type || '-' %> <%= log.target_id || '' %></td>
            <td>
              <span class="badge <%= log.success ? 'success' : 'pending' %>">
                <%= log.success ? 'Yes' : 'No' %>
              </span>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>
<%- include('partials/footer') %>
